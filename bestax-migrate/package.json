{
  "name": "bestax-migrate",
  "version": "1.0.0",
  "description": "Codemods for migrating existing React apps from other Bulma libraries to @allxsmith/bestax-bulma",
  "type": "module",
  "bin": {
    "bestax-migrate": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:watch": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch",
    "test:coverage": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --coverage",
    "lint": "eslint src e2e",
    "typecheck": "tsc --noEmit",
    "validate:corpus": "pnpm run build && node scripts/validate-corpus.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\"",
    "clean": "rimraf dist",
    "release": "npx semantic-release"
  },
  "keywords": [
    "bestax",
    "bulma",
    "react",
    "codemod",
    "jscodeshift",
    "migration",
    "react-bulma-components"
  ],
  "author": "Alex Smith",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allxsmith/bestax.git",
    "directory": "bestax-migrate"
  },
  "homepage": "https://bestax.io",
  "llms": "https://bestax.io/llms.txt",
  "bugs": {
    "url": "https://github.com/allxsmith/bestax/issues"
  },
  "dependencies": {
    "@allxsmith/bestax-bulma": "workspace:^",
    "@babel/parser": "^7.26.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "jscodeshift": "^17.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^30.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
