{
  "name": "@allxsmith/bestax-bulma",
  "version": "5.4.1",
  "description": "A fully-typed React component library for the Bulma CSS framework. Build modern UIs quickly with reusable, accessible, and customizable Bulma-based React components.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src/scss",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "watch": "rollup -c --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "bundle:stats": "rollup -c --configPlugin visualizer",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist",
    "storybook": "storybook dev -p 6006",
    "start": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "npx semantic-release"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mdi/font": "^7.4.47",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.0",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.1.11",
    "ionicons": "^8.0.13",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.45.2",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "rollup": "^4.55.1",
    "rollup-plugin-scss": "^4.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.97.2",
    "storybook": "^10.1.11",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "bulma": "^1.0.4"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2 || ^7.0.0",
    "@mdi/font": "^7.4.47",
    "ionicons": "^8.0.0",
    "material-icons": "^1.13.10",
    "material-symbols": "^0.34.1 || ^0.45.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@fortawesome/fontawesome-free": {
      "optional": true
    },
    "@mdi/font": {
      "optional": true
    },
    "ionicons": {
      "optional": true
    },
    "material-icons": {
      "optional": true
    },
    "material-symbols": {
      "optional": true
    }
  },
  "keywords": [
    "react",
    "bulma",
    "typescript",
    "components"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./dist/extras.css": {
      "default": "./dist/extras.css"
    },
    "./extras.css": {
      "default": "./dist/extras.css"
    },
    "./dist/bestax.css": {
      "default": "./dist/bestax.css"
    },
    "./bestax.css": {
      "default": "./dist/bestax.css"
    },
    "./bestax.min.css": {
      "default": "./dist/bestax.css"
    },
    "./dist/bestax.min.css": {
      "default": "./dist/bestax.css"
    },
    "./versions/bestax-prefixed.css": {
      "default": "./dist/versions/bestax-prefixed.css"
    },
    "./dist/versions/bestax-prefixed.css": {
      "default": "./dist/versions/bestax-prefixed.css"
    },
    "./versions/bestax-no-helpers.css": {
      "default": "./dist/versions/bestax-no-helpers.css"
    },
    "./dist/versions/bestax-no-helpers.css": {
      "default": "./dist/versions/bestax-no-helpers.css"
    },
    "./versions/bestax-no-helpers-prefixed.css": {
      "default": "./dist/versions/bestax-no-helpers-prefixed.css"
    },
    "./dist/versions/bestax-no-helpers-prefixed.css": {
      "default": "./dist/versions/bestax-no-helpers-prefixed.css"
    },
    "./versions/bestax-no-dark-mode.css": {
      "default": "./dist/versions/bestax-no-dark-mode.css"
    },
    "./dist/versions/bestax-no-dark-mode.css": {
      "default": "./dist/versions/bestax-no-dark-mode.css"
    },
    "./scss": {
      "default": "./src/scss/extras.scss"
    },
    "./scss/bestax": {
      "default": "./src/scss/bestax.scss"
    },
    "./scss/*": {
      "default": "./src/scss/*"
    }
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/allxsmith"
  },
  "engines": {
    "node": ">=16",
    "npm": ">=7"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/types/*"
      ]
    }
  },
  "author": "Alex Smith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allxsmith/bestax.git",
    "directory": "bulma-ui"
  },
  "homepage": "https://bestax.io",
  "llms": "https://bestax.io/llms.txt",
  "bugs": {
    "url": "https://github.com/allxsmith/bestax/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
