+import type { PageProps } from '../routes';
+
+const HONESTY_METRICS = [
+  {
+    metric: 'Unsupported assertions',
+    skynet: '0.4%',
+    fable: '4.0%',
+    note: 'Claims made without evidence in the provided context',
