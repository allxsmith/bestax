+            subtitle="Reported next to capability scores, on every release, whether or not they improved."
+            mb="5"
+          />
+          <Box>
+            <Table isStriped isHoverable isFullwidth>
+              <Table.Thead>
+                <Table.Tr>
+                  <Table.Th>Metric</Table.Th>
