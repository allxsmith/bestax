+              {BENCHMARKS.map(row => (
+                <Table.Tr key={row.suite}>
+                  <Table.Td textWeight="semibold">{row.suite}</Table.Td>
+                  <Table.Td>
+                    <Span textColor="grey">{row.what}</Span>
+                  </Table.Td>
+                  <Table.Td textAlign="right">
+                    <Span textColor="link" textWeight="bold">
