+            <Block>
+              <Icon
+                name="github"
+                variant="brands"
+                textColor="grey"
+                mr="4"
+                ariaLabel="Netadyne on GitHub"
+              />
+              <Icon
+                name="x-twitter"
+                variant="brands"
+                textColor="grey"
+                mr="4"
+                ariaLabel="Netadyne on X"
+              />
+              <Icon
+                name="linkedin"
+                variant="brands"
+                textColor="grey"
