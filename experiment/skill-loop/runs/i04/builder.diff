+  {
+    heading: 'Developers',
+    links: [
+      { label: 'Quickstart', route: 'docs' },
+      { label: 'API reference', route: 'docs' },
+      { label: 'Cookbook' },
+      { label: 'Status' },
+      { label: 'Support' },
+    ],
+  },
+  {
+    heading: 'Company',
+    links: [
