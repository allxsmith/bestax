+interface FooterLink {
+  label: string;
+  route?: Route;
+}
+
+const COLUMNS: { heading: string; links: FooterLink[] }[] = [
+  {
+    heading: 'Product',
+    links: [
+      { label: 'Overview', route: 'product' },
