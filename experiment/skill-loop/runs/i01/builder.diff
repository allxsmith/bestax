+                        <Table.Td className="has-text-weight-bold">
+                          {error.code}
+                        </Table.Td>
+                        <Table.Td>
+                          <code>{error.name}</code>
+                        </Table.Td>
+                        <Table.Td className="has-text-grey is-size-7">
