+                iconProps={{ name: 'check', 'aria-hidden': 'true' }}
+                textColor="grey"
+              >
+                {item}
+              </IconText>
+            </ListItem>
+          ))}
+        </UnorderedList>
+      </Card.Content>
+    </Card>
+  );
+}
