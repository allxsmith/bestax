+        </Container>
+      </Section>
+
+      <Section size="large" className="section-alt">
+        <Container>
+          <Title size="2" mb="2">
+            Token pricing
+          </Title>
+          <Paragraph textColor="grey" mb="5">
+            Per million tokens, in US dollars. Batch requests are half price on
+            every model; cached input reads are 90% off.
