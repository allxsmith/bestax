+                  <Notification
+                    color="success"
+                    isLight
+                    onDelete={() => setDone(false)}
+                  >
+                    <Strong>Request received.</Strong> Check your inbox for a
+                    sandbox key and $25 in credits. (Demo form — nothing was
+                    actually sent.)
