+      <Button
+        color="primary"
+        isOutlined={!plan.featured}
+        isFullWidth
+        mt="5"
+        onClick={() => onNavigate('contact')}
+      >
+        {plan.cta}
+      </Button>
+    </Box>
+  );
+}
