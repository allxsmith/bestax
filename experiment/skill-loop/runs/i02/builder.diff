+  Paragraph,
+  Section,
+  Span,
+  Strong,
+  SubTitle,
+  Switch,
+  Table,
+  Tag,
+  Tbody,
+  Td,
+  Th,
+  Thead,
+  Title,
+  Tr,
+} from '@allxsmith/bestax-bulma';
+import { FAQS, PLANS, TOKEN_PRICING, type PageId } from '../site/content';
+
+export default function PricingPage({
